    role: "\u81EA\u8EAB\u306E\u9632\u5FA1\u3092\u72A0\u7272\u306B\u3001\u30D4\u30F3\u30C1\u306E\u5473\u65B9\u306E\u653B\u6483\u529B\u3092\u7206\u767A\u7684\u306B\u9AD8\u3081\u308B\u652F\u63F4\u7279\u5316\u30D2\u30FC\u30E9\u30FC\u3002"
